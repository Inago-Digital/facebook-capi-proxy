{
  "name": "fb-capi-proxy",
  "version": "1.0.0",
  "description": "Multi-tenant Facebook Conversions API proxy server and dashboard",
  "main": "dist/index.js",
  "scripts": {
    "start": "concurrently \"npm run start:server\" \"npm run start:dashboard\"",
    "start:server": "npm run dev --prefix server",
    "start:dashboard": "npm run dev --prefix dashboard",
    "build": "concurrently \"npm run build:server\" \"npm run build:dashboard\"",
    "build:server": "cd server && npm run build",
    "build:dashboard": "cd dashboard && npm run build"
  },
  "dependencies": {
    "concurrently": "^7.6.0"
  },
  "devDependencies": {}
}