# ── Server ──────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Database ─────────────────────────────────────────────
# Choose ONE: "sqlite" or "postgres"
DB_DRIVER=sqlite

# SQLite path (used when DB_DRIVER=sqlite)
SQLITE_PATH=./data/proxy.db

# Postgres connection string (used when DB_DRIVER=postgres)
# DATABASE_URL=postgresql://user:password@localhost:5432/fb_capi_proxy

# ── Admin auth ───────────────────────────────────────────
# Secret used only for POST /admin/auth/login
ADMIN_SECRET=change-me-to-a-long-random-string
# Comma-separated list of allowed dashboard origins for /admin CORS
ADMIN_ALLOWED_ORIGINS=http://localhost:5173
# Access token lifetime in minutes
ADMIN_ACCESS_TTL_MINUTES=15
# Refresh token lifetime in days
ADMIN_REFRESH_TTL_DAYS=7

# ── Rate limiting ────────────────────────────────────────
# Max requests per IP per 15 minutes on /event endpoint
RATE_LIMIT_MAX=200
# Per-site/IP max accepted /event requests in window below
EVENT_SITE_RATE_LIMIT_MAX=120
# Window for per-site/IP limiter in milliseconds
EVENT_SITE_RATE_LIMIT_WINDOW_MS=900000

# ── Event endpoint hardening ─────────────────────────────
# Short-lived access token lifetime for /event/auth in seconds
EVENT_ACCESS_TTL_SECONDS=300
# Keep replay-dedup IDs for this many hours
EVENT_DEDUP_TTL_HOURS=48
# Require Origin/Referer match with site domain
EVENT_REQUIRE_ORIGIN=true
# Require event_source_url on each event and enforce matching origin
EVENT_REQUIRE_EVENT_SOURCE_URL=true
# Bind issued event tokens to caller IP (optional, stricter but less tolerant)
EVENT_TOKEN_BIND_IP=false

# ── Facebook CAPI ────────────────────────────────────────
FB_CAPI_URL=https://graph.facebook.com/v19.0
